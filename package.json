{
  "name": "remote-org-chart",
  "version": "1.0.0",
  "description": "Org chart on Remote's API — interactive tree/list views with an Express proxy and snapshot fallback",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "dev": "concurrently \"vite\" \"tsx watch server/index.ts\"",
    "build": "vite build && tsc -p tsconfig.server.json",
    "docs:build": "npm --prefix website ci && npm --prefix website run build",
    "docs:dev": "npm --prefix website start",
    "start": "node dist-server/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint ."
  },
  "dependencies": {
    "express": "^4.19.2",
    "react": "^18.3.1",
    "react-d3-tree": "^3.6.6",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.3.4",
    "vitest": "^2.0.3"
  }
}
